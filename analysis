<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RepoScope — Top-100 Analyse</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#06080f;--surface:#0c1018;--surface2:#111722;--border:#1c2535;--border2:#253045;--accent:#3dffa0;--accent-d:rgba(61,255,160,.08);--accent2:#5b9cf6;--amber:#f5c842;--red:#f75f6c;--text:#dce6f5;--muted:#566880;--p1:#3dffa0;--p2:#5b9cf6;--p3:#f5c842;--mono:'IBM Plex Mono',monospace;--sans:'DM Sans',sans-serif;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(61,255,160,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(61,255,160,.018) 1px,transparent 1px);background-size:48px 48px;}
nav{position:sticky;top:0;z-index:200;background:rgba(6,8,15,.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:.65rem 2rem;}
.nav-logo{font-family:var(--mono);font-size:.95rem;font-weight:700;text-decoration:none;letter-spacing:-.02em;}
.nav-logo b{color:var(--accent);}.nav-logo span{color:var(--text);}
.nav-links{display:flex;gap:.25rem;}
.nav-link{font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;color:var(--muted);padding:.4rem .9rem;border-radius:6px;transition:background .2s,color .2s;}
.nav-link:hover{background:var(--surface2);color:var(--text);}
.nav-link.active{background:var(--accent-d);color:var(--accent);}
.page-hdr{max-width:1400px;margin:0 auto;padding:2.25rem 2rem 1.25rem;position:relative;z-index:1;}
.page-title{font-size:clamp(1.5rem,4vw,2.2rem);font-weight:800;margin-bottom:.3rem;}
.page-title span{color:var(--accent);}
.page-sub{font-family:var(--mono);font-size:.7rem;color:var(--muted);letter-spacing:.06em;}
.demo-banner{max-width:1400px;margin:0 auto .75rem;padding:0 2rem;position:relative;z-index:1;}
.demo-inner{background:rgba(245,200,66,.07);border:1px solid rgba(245,200,66,.2);border-radius:9px;padding:.65rem 1.1rem;font-family:var(--mono);font-size:.7rem;color:var(--amber);}
.demo-inner code{background:rgba(245,200,66,.12);padding:.1rem .4rem;border-radius:3px;font-size:.65rem;}
.stats-row{max-width:1400px;margin:0 auto 1.25rem;padding:0 2rem;display:grid;grid-template-columns:repeat(4,1fr);gap:.85rem;position:relative;z-index:1;}
@media(max-width:900px){.stats-row{grid-template-columns:repeat(2,1fr);}}
.sc{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:1.1rem 1.3rem;display:flex;align-items:center;gap:.85rem;}
.sc-icon{font-size:1.4rem;flex-shrink:0;}
.sc-val{font-family:var(--mono);font-size:1.3rem;font-weight:700;color:var(--accent);line-height:1;}
.sc-lbl{font-family:var(--mono);font-size:.6rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:.15rem;}
.ctrl-row{max-width:1400px;margin:0 auto 1rem;padding:0 2rem;display:flex;gap:.65rem;flex-wrap:wrap;position:relative;z-index:1;align-items:center;}
.ctrl-in{flex:1;min-width:200px;background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:.6rem 1rem;color:var(--text);font-family:var(--mono);font-size:.78rem;outline:none;transition:border-color .2s;}
.ctrl-in:focus{border-color:var(--accent);}
.ctrl-in::placeholder{color:var(--muted);}
.ctrl-sel{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:.6rem .9rem;color:var(--text);font-family:var(--mono);font-size:.75rem;outline:none;cursor:pointer;}
.ctrl-sel option{background:var(--surface2);}
.btn-reset{background:none;border:1px solid var(--border);border-radius:9px;padding:.6rem 1rem;color:var(--muted);font-family:var(--mono);font-size:.72rem;cursor:pointer;transition:all .2s;}
.btn-reset:hover{border-color:var(--accent);color:var(--accent);}
.ctrl-count{font-family:var(--mono);font-size:.7rem;color:var(--muted);white-space:nowrap;margin-left:auto;}
.tbl-wrap{max-width:1400px;margin:0 auto 6rem;padding:0 2rem;position:relative;z-index:1;}
.tbl-scroll{overflow-x:auto;border:1px solid var(--border);border-radius:14px;}
table{width:100%;border-collapse:collapse;font-size:.8rem;min-width:1100px;}
thead tr{background:var(--surface2);border-bottom:1px solid var(--border);}
th{padding:.7rem .9rem;text-align:left;font-family:var(--mono);font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);white-space:nowrap;user-select:none;cursor:pointer;}
th:first-child{cursor:default;padding:.7rem .7rem .7rem 1.1rem;}
th.s-asc,th.s-desc{color:var(--accent);}
th.s-asc .si::after{content:' ↑';}th.s-desc .si::after{content:' ↓';}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s;cursor:pointer;}
tbody tr:last-child{border-bottom:none;}
tbody tr:hover{background:rgba(61,255,160,.025);}
tbody tr.sel{background:rgba(61,255,160,.05);}
td{padding:.65rem .9rem;vertical-align:middle;}
td:first-child{padding-left:1.1rem;}
.td-rank{font-family:var(--mono);font-size:.7rem;color:var(--muted);text-align:center;}
.rn{font-weight:700;font-size:.82rem;color:var(--text);text-decoration:none;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px;transition:color .2s;}
.rn:hover{color:var(--accent);}
.rd{font-family:var(--mono);font-size:.66rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:210px;display:block;margin-top:.1rem;}
.lang-b{display:inline-block;font-family:var(--mono);font-size:.63rem;padding:.18rem .5rem;border-radius:5px;white-space:nowrap;}
.tn{font-family:var(--mono);font-size:.76rem;text-align:right;white-space:nowrap;}
.sbar{min-width:85px;}
.sbar-w{display:flex;align-items:center;gap:.4rem;}
.sbar-bg{flex:1;height:4px;background:var(--border);border-radius:999px;overflow:hidden;min-width:36px;}
.sbar-fill{height:100%;border-radius:999px;transition:width .8s ease;}
.sbar-n{font-family:var(--mono);font-size:.7rem;font-weight:700;width:22px;text-align:right;}
.overall-b{font-family:var(--mono);font-size:.82rem;font-weight:700;display:inline-flex;align-items:center;gap:.3rem;}
.gp{font-size:.6rem;padding:.08rem .32rem;border-radius:4px;}
input[type=checkbox]{width:14px;height:14px;accent-color:var(--accent);cursor:pointer;}
.no-res{padding:4rem 2rem;text-align:center;font-family:var(--mono);font-size:.8rem;color:var(--muted);}
.cfab{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);z-index:150;background:var(--accent);color:var(--bg);border:none;border-radius:999px;padding:.8rem 1.75rem;cursor:pointer;font-family:var(--mono);font-size:.8rem;font-weight:700;white-space:nowrap;box-shadow:0 8px 28px rgba(61,255,160,.3);transition:transform .2s,box-shadow .2s,opacity .2s;opacity:0;pointer-events:none;display:flex;align-items:center;gap:.55rem;}
.cfab.vis{opacity:1;pointer-events:all;}
.cfab:hover{transform:translateX(-50%) translateY(-2px);box-shadow:0 12px 36px rgba(61,255,160,.4);}
.cfab-n{background:var(--bg);color:var(--accent);border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;}
.modal-ov{position:fixed;inset:0;z-index:300;background:rgba(6,8,15,.85);backdrop-filter:blur(8px);display:flex;align-items:flex-start;justify-content:center;overflow-y:auto;padding:2rem 1rem 3rem;opacity:0;pointer-events:none;transition:opacity .25s;}
.modal-ov.open{opacity:1;pointer-events:all;}
.modal-box{background:var(--surface);border:1px solid var(--border);border-radius:18px;width:100%;max-width:1150px;overflow:hidden;transform:translateY(20px);transition:transform .3s cubic-bezier(.4,0,.2,1);}
.modal-ov.open .modal-box{transform:translateY(0);}
.modal-hdr{padding:1.25rem 1.75rem 1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.modal-title{font-family:var(--mono);font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);}
.modal-x{background:var(--surface2);border:1px solid var(--border);border-radius:7px;width:30px;height:30px;color:var(--muted);cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:.9rem;}
.modal-x:hover{color:var(--text);border-color:var(--text);}
.modal-body{padding:1.75rem;overflow-x:auto;}
.cmp-grid{display:grid;gap:.85rem;}
.cmp-card{background:var(--surface2);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.cmp-head{padding:1.1rem 1.1rem .7rem;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:.65rem;}
.cmp-av{width:34px;height:34px;border-radius:7px;flex-shrink:0;}
.cmp-rn{font-weight:700;font-size:.84rem;text-decoration:none;color:var(--text);display:block;transition:color .2s;word-break:break-all;line-height:1.2;}
.cmp-rn:hover{color:var(--accent);}
.cmp-lang{font-family:var(--mono);font-size:.63rem;color:var(--muted);margin-top:.2rem;}
.cmp-ov{margin-left:auto;flex-shrink:0;font-family:var(--mono);font-size:1.45rem;font-weight:700;line-height:1;}
.cmp-body{padding:1.1rem;}
.cpm{margin-bottom:.9rem;}.cpm:last-child{margin-bottom:0;}
.cpm-h{display:flex;justify-content:space-between;margin-bottom:.28rem;}
.cpm-l{font-size:.7rem;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:.08em;}
.cpm-v{font-size:.76rem;font-family:var(--mono);font-weight:700;}
.cpm-bg{height:6px;background:var(--border);border-radius:999px;overflow:hidden;}
.cpm-fill{height:100%;border-radius:999px;transition:width 1s cubic-bezier(.4,0,.2,1);}
.csep{margin:1rem 0;border:none;border-top:1px solid var(--border);}
.ckv{display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px solid var(--border);font-size:.74rem;}
.ckv:last-child{border-bottom:none;}
.ckv-l{color:var(--muted);font-family:var(--mono);font-size:.68rem;}
.ckv-v{font-family:var(--mono);font-size:.74rem;font-weight:700;}
.wb{display:inline-block;font-family:var(--mono);font-size:.58rem;background:rgba(61,255,160,.1);color:var(--accent);border-radius:3px;padding:.02rem .3rem;margin-left:.3rem;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.anim{opacity:0;animation:fadeUp .4s ease forwards;}
.a1{animation-delay:.05s;}.a2{animation-delay:.10s;}.a3{animation-delay:.15s;}.a4{animation-delay:.20s;}
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="index.html"><b>Repo</b><span>Scope</span></a>
  <div class="nav-links">
    <a class="nav-link" href="index.html">🔍 Analyzer</a>
    <a class="nav-link active" href="analysis.html">📊 Top-100 Analyse</a>
  </div>
</nav>

<div class="page-hdr">
  <h1 class="page-title">Top-100 <span>Open-Source</span> Projekte</h1>
  <p class="page-sub">CHAOSS 3-Säulen-Scoring · Median-Benchmark · Täglich aktualisiert · Sortierbar · Vergleichbar</p>
</div>

<div class="demo-banner" id="demoBanner" style="display:none">
  <div class="demo-inner">
    ⚠ Demo-Daten — Führe <code>python collect_data.py</code> aus und pushe
    <code>data/top100_repos.json</code> für echte Top-100-Daten.
  </div>
</div>

<div class="stats-row">
  <div class="sc anim a1"><div class="sc-icon">📦</div><div><div class="sc-val" id="stTotal">—</div><div class="sc-lbl">Repositories</div></div></div>
  <div class="sc anim a2"><div class="sc-icon">⭐</div><div><div class="sc-val" id="stAvg">—</div><div class="sc-lbl">Ø Gesamt-Score</div></div></div>
  <div class="sc anim a3"><div class="sc-icon">🏆</div><div><div class="sc-val" id="stTop">—</div><div class="sc-lbl">Höchster Score</div></div></div>
  <div class="sc anim a4"><div class="sc-icon">🌐</div><div><div class="sc-val" id="stLang">—</div><div class="sc-lbl">Häufigste Sprache</div></div></div>
</div>

<div class="ctrl-row">
  <input class="ctrl-in" type="text" id="searchIn" placeholder="🔍 Repository suchen …" oninput="applyFilters()">
  <select class="ctrl-sel" id="langSel" onchange="applyFilters()"><option value="">Alle Sprachen</option></select>
  <select class="ctrl-sel" id="sortSel" onchange="applyFilters()">
    <option value="rank-asc">Rang ↑</option>
    <option value="overall-desc">Gesamt-Score ↓</option>
    <option value="p1-desc">⚡ Aktivität ↓</option>
    <option value="p2-desc">🔧 Reaktionsfähigkeit ↓</option>
    <option value="p3-desc">📡 Reichweite ↓</option>
    <option value="stars-desc">Stars ↓</option>
    <option value="commits30-desc">Commits/30T ↓</option>
    <option value="closeRate-desc">Close-Rate ↓</option>
    <option value="contributors-desc">Contributors ↓</option>
    <option value="name-asc">Name A–Z</option>
  </select>
  <select class="ctrl-sel" id="minSel" onchange="applyFilters()">
    <option value="0">Alle Scores</option>
    <option value="80">Score ≥ 80</option>
    <option value="70">Score ≥ 70</option>
    <option value="60">Score ≥ 60</option>
  </select>
  <button class="btn-reset" onclick="resetFilters()">✕ Reset</button>
  <span class="ctrl-count" id="ctrlCnt">—</span>
</div>

<div class="tbl-wrap">
  <div class="tbl-scroll">
    <table>
      <thead><tr>
        <th><input type="checkbox" id="selAll" onclick="toggleAll(this)"></th>
        <th>#</th>
        <th style="min-width:210px">Repository</th>
        <th>Sprache</th>
        <th style="text-align:right">⭐ Stars</th>
        <th style="text-align:right">📝 Commits/30T</th>
        <th style="text-align:right">✅ Close%</th>
        <th style="text-align:right">👥 Contributors</th>
        <th class="sbar">⚡ <span class="si">Aktivität</span></th>
        <th class="sbar">🔧 <span class="si">Reaktion</span></th>
        <th class="sbar">📡 <span class="si">Reichweite</span></th>
        <th>Gesamt</th>
      </tr></thead>
      <tbody id="tbody"><tr><td colspan="12" class="no-res">Lade Daten…</td></tr></tbody>
    </table>
  </div>
</div>

<button class="cfab" id="cfab" onclick="openModal()">
  Vergleichen <span class="cfab-n" id="cfabN">0</span>
</button>

<div class="modal-ov" id="modal" onclick="closeOv(event)">
  <div class="modal-box">
    <div class="modal-hdr">
      <span class="modal-title">⚖ Repository-Vergleich</span>
      <button class="modal-x" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body" id="modalBody"></div>
  </div>
</div>

<script>
const LC={JavaScript:{bg:'rgba(247,223,30,.1)',fg:'#f7df1e'},TypeScript:{bg:'rgba(79,120,198,.15)',fg:'#4f90d9'},Python:{bg:'rgba(55,118,171,.15)',fg:'#4fa8d9'},'C++':{bg:'rgba(243,75,125,.1)',fg:'#f34b7d'},C:{bg:'rgba(85,85,85,.2)',fg:'#a0a0a0'},Go:{bg:'rgba(0,173,216,.1)',fg:'#00add8'},Rust:{bg:'rgba(206,66,43,.1)',fg:'#ce422b'},Java:{bg:'rgba(176,114,25,.15)',fg:'#e0952e'},PHP:{bg:'rgba(119,123,179,.15)',fg:'#9fa3d9'},Ruby:{bg:'rgba(112,21,22,.15)',fg:'#d1414e'},Shell:{bg:'rgba(137,224,81,.1)',fg:'#89e051'},Swift:{bg:'rgba(240,81,56,.1)',fg:'#f05138'},Kotlin:{bg:'rgba(169,123,255,.1)',fg:'#a97bff'},default:{bg:'rgba(100,116,139,.15)',fg:'#94a3b8'}};
function lc(l){const c=LC[l]||LC.default;return`background:${c.bg};color:${c.fg};border:1px solid ${c.fg}33`;}

/* Demo data in our format */
const SAMPLE=[
  {rank:1,full_name:'freeCodeCamp/freeCodeCamp',html_url:'https://github.com/freeCodeCamp/freeCodeCamp',description:'freeCodeCamp.org open-source codebase and curriculum',language:'TypeScript',license:'BSD-3-Clause',stars:392000,forks:36300,open_issues:245,age_days:3900,kpis:{commits30:112,daysInactive:0,contributors:98,closeRate:.78,relFreq:null,avgClose:8.2,avgComments:4.2,fehlerProd:.089,forkRatio:.093,doku:100,starsTage:100.5},scores:{p1:88,p2:72,p3:82,overall:82}},
  {rank:2,full_name:'facebook/react',html_url:'https://github.com/facebook/react',description:'The library for web and native user interfaces.',language:'JavaScript',license:'MIT',stars:228000,forks:47000,open_issues:780,age_days:4700,kpis:{commits30:95,daysInactive:1,contributors:100,closeRate:.39,relFreq:42,avgClose:18,avgComments:5.1,fehlerProd:.062,forkRatio:.206,doku:100,starsTage:48.5},scores:{p1:91,p2:75,p3:78,overall:83}},
  {rank:3,full_name:'microsoft/vscode',html_url:'https://github.com/microsoft/vscode',description:'Visual Studio Code',language:'TypeScript',license:'MIT',stars:164000,forks:29600,open_issues:6800,age_days:3300,kpis:{commits30:185,daysInactive:1,contributors:100,closeRate:.13,relFreq:10,avgClose:45,avgComments:6.8,fehlerProd:.009,forkRatio:.180,doku:100,starsTage:49.7},scores:{p1:94,p2:71,p3:76,overall:82}},
  {rank:4,full_name:'vercel/next.js',html_url:'https://github.com/vercel/next.js',description:'The React Framework',language:'JavaScript',license:'MIT',stars:127000,forks:27000,open_issues:3200,age_days:3100,kpis:{commits30:145,daysInactive:1,contributors:100,closeRate:.48,relFreq:7,avgClose:12,avgComments:5.5,fehlerProd:.050,forkRatio:.213,doku:100,starsTage:41.0},scores:{p1:92,p2:88,p3:77,overall:87}},
  {rank:5,full_name:'kubernetes/kubernetes',html_url:'https://github.com/kubernetes/kubernetes',description:'Production-Grade Container Scheduling and Management',language:'Go',license:'Apache-2.0',stars:111000,forks:40000,open_issues:2500,age_days:3900,kpis:{commits30:210,daysInactive:1,contributors:100,closeRate:.72,relFreq:90,avgClose:30,avgComments:7.2,fehlerProd:.062,forkRatio:.360,doku:100,starsTage:28.5},scores:{p1:97,p2:81,p3:76,overall:86}},
];

let allData=[], filtered=[], selected=new Set();

async function loadData(){
  try{
    const r=await fetch('data/top100_repos.json');
    if(!r.ok)throw new Error();
    allData=await r.json();
  }catch(_){
    allData=SAMPLE;
    document.getElementById('demoBanner').style.display='';
  }
  initFilters();renderStats();applyFilters();
}

function initFilters(){
  const langs=[...new Set(allData.map(r=>r.language).filter(Boolean))].sort();
  const sel=document.getElementById('langSel');
  langs.forEach(l=>{const o=document.createElement('option');o.value=o.textContent=l;sel.appendChild(o);});
}

function renderStats(){
  const scores=allData.map(r=>r.scores?.overall).filter(s=>s!=null);
  const avg=scores.length?Math.round(scores.reduce((a,b)=>a+b,0)/scores.length):0;
  const top=scores.length?Math.max(...scores):0;
  const lf={};allData.forEach(r=>{if(r.language)lf[r.language]=(lf[r.language]||0)+1;});
  const topL=Object.entries(lf).sort(([,a],[,b])=>b-a)[0]?.[0]||'—';
  document.getElementById('stTotal').textContent=allData.length;
  document.getElementById('stAvg').textContent=avg;
  document.getElementById('stTop').textContent=top;
  document.getElementById('stLang').textContent=topL;
}

function applyFilters(){
  const q=document.getElementById('searchIn').value.trim().toLowerCase();
  const lng=document.getElementById('langSel').value;
  const[sk,sd]=document.getElementById('sortSel').value.split('-');
  const min=+document.getElementById('minSel').value||0;
  filtered=allData.filter(r=>{
    if(q&&!r.full_name.toLowerCase().includes(q)&&!(r.description||'').toLowerCase().includes(q))return false;
    if(lng&&r.language!==lng)return false;
    if((r.scores?.overall||0)<min)return false;
    return true;
  });
  filtered.sort((a,b)=>{
    let va,vb;
    switch(sk){
      case'rank':va=a.rank;vb=b.rank;break;
      case'overall':va=a.scores?.overall||0;vb=b.scores?.overall||0;break;
      case'p1':va=a.scores?.p1||0;vb=b.scores?.p1||0;break;
      case'p2':va=a.scores?.p2||0;vb=b.scores?.p2||0;break;
      case'p3':va=a.scores?.p3||0;vb=b.scores?.p3||0;break;
      case'stars':va=a.stars||0;vb=b.stars||0;break;
      case'commits30':va=a.kpis?.commits30||0;vb=b.kpis?.commits30||0;break;
      case'closeRate':va=a.kpis?.closeRate||0;vb=b.kpis?.closeRate||0;break;
      case'contributors':va=a.kpis?.contributors||0;vb=b.kpis?.contributors||0;break;
      case'name':va=a.full_name.toLowerCase();vb=b.full_name.toLowerCase();break;
      default:va=a.rank;vb=b.rank;
    }
    if(va<vb)return sd==='asc'?-1:1;if(va>vb)return sd==='asc'?1:-1;return 0;
  });
  renderTable();
  document.getElementById('ctrlCnt').textContent=`${filtered.length} / ${allData.length} Repos`;
}

function resetFilters(){document.getElementById('searchIn').value='';document.getElementById('langSel').value='';document.getElementById('sortSel').value='rank-asc';document.getElementById('minSel').value='0';applyFilters();}

function fmt(n){if(!n&&n!==0)return'—';if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return String(Math.round(n));}
function sc(s){return s>=70?'#3dffa0':s>=45?'#f5c842':'#f75f6c';}
function gr(s){return s>=90?'A+':s>=80?'A':s>=70?'B+':s>=60?'B':s>=50?'C':s>=40?'D':'F';}
function mbar(score,col){const c=col||sc(score||0);return`<div class="sbar-w"><div class="sbar-bg"><div class="sbar-fill" style="width:${score||0}%;background:${c}"></div></div><span class="sbar-n" style="color:${c}">${score??'—'}</span></div>`;}

function renderTable(){
  const tbody=document.getElementById('tbody');
  if(!filtered.length){tbody.innerHTML=`<tr><td colspan="12" class="no-res">Keine Repos für diese Filter.</td></tr>`;return;}
  tbody.innerHTML=filtered.map(r=>{
    const isSel=selected.has(r.full_name);
    const s=r.scores||{},k=r.kpis||{};
    const cr=k.closeRate!=null?(k.closeRate*100).toFixed(0)+'%':'—';
    return`<tr class="${isSel?'sel':''}" onclick="rowClick(event,'${r.full_name.replace(/'/g,"\\'")}')">
      <td><input type="checkbox" ${isSel?'checked':''} onclick="toggleSel(event,'${r.full_name.replace(/'/g,"\\'")}')"></td>
      <td class="td-rank">${r.rank}</td>
      <td>
        <a class="rn" href="${r.html_url||'https://github.com/'+r.full_name}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${r.full_name}</a>
        <span class="rd">${(r.description||'').slice(0,55)}${(r.description||'').length>55?'…':''}</span>
      </td>
      <td>${r.language?`<span class="lang-b" style="${lc(r.language)}">${r.language}</span>`:'<span style="color:var(--muted);font-size:.7rem">—</span>'}</td>
      <td class="tn" style="color:var(--accent)">${fmt(r.stars)}</td>
      <td class="tn">${k.commits30??'—'}</td>
      <td class="tn" style="color:${k.closeRate!=null?(k.closeRate>=.4?'#3dffa0':k.closeRate>=.2?'#f5c842':'#f75f6c'):'var(--muted)'}">${cr}</td>
      <td class="tn">${k.contributors??'—'}</td>
      <td class="sbar">${mbar(s.p1,'#3dffa0')}</td>
      <td class="sbar">${mbar(s.p2,'#5b9cf6')}</td>
      <td class="sbar">${mbar(s.p3,'#f5c842')}</td>
      <td><span class="overall-b" style="color:${sc(s.overall||0)}">${s.overall??'—'}<span class="gp" style="background:rgba(61,255,160,.1);color:${sc(s.overall||0)}">${s.overall!=null?gr(s.overall):''}</span></span></td>
    </tr>`;
  }).join('');
}

function rowClick(e,fn){if(e.target.tagName==='INPUT'||e.target.tagName==='A')return;toggleSel(e,fn);}
function toggleSel(e,fn){
  e.stopPropagation();
  if(selected.has(fn)){selected.delete(fn);}else{
    if(selected.size>=5){alert('Max. 5 Repos gleichzeitig.');if(e.target.tagName==='INPUT')e.target.checked=false;return;}
    selected.add(fn);
  }
  updateSel();renderTable();
}
function toggleAll(cb){if(cb.checked)filtered.slice(0,5).forEach(r=>selected.add(r.full_name));else filtered.forEach(r=>selected.delete(r.full_name));updateSel();renderTable();}
function updateSel(){const n=selected.size;document.getElementById('cfabN').textContent=n;document.getElementById('cfab').classList.toggle('vis',n>=2);}

function openModal(){const repos=allData.filter(r=>selected.has(r.full_name));if(repos.length<2)return;renderModal(repos);document.getElementById('modal').classList.add('open');document.body.style.overflow='hidden';}
function closeModal(){document.getElementById('modal').classList.remove('open');document.body.style.overflow='';}
function closeOv(e){if(e.target===document.getElementById('modal'))closeModal();}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

function renderModal(repos){
  const n=repos.length;
  const best={};
  ['p1','p2','p3','overall'].forEach(k=>{best[k]=Math.max(...repos.map(r=>r.scores?.[k]||0));});
  best.stars=Math.max(...repos.map(r=>r.stars||0));
  const grid=document.createElement('div');
  grid.className='cmp-grid';
  grid.style.gridTemplateColumns=`repeat(${n},minmax(200px,1fr))`;
  repos.forEach(r=>{
    const[owner]=r.full_name.split('/');
    const s=r.scores||{},k=r.kpis||{};
    const card=document.createElement('div');
    card.className='cmp-card';
    card.innerHTML=`
      <div class="cmp-head">
        <img class="cmp-av" src="https://github.com/${owner}.png?size=68" alt="${owner}" loading="lazy">
        <div style="flex:1;min-width:0">
          <a class="cmp-rn" href="${r.html_url||'https://github.com/'+r.full_name}" target="_blank">${r.full_name}</a>
          <div class="cmp-lang">${r.language||'—'} · ${r.license||'—'}</div>
        </div>
        <div class="cmp-ov" style="color:${sc(s.overall||0)}">${s.overall??'—'}${s.overall===best.overall?'<br><span style="font-size:.52rem;color:var(--accent);letter-spacing:.05em">BEST</span>':''}</div>
      </div>
      <div class="cmp-body">
        ${[{k:'p1',l:'⚡ Aktivität',c:'#3dffa0'},{k:'p2',l:'🔧 Reaktionsfähigkeit',c:'#5b9cf6'},{k:'p3',l:'📡 Reichweite',c:'#f5c842'}].map(d=>`
        <div class="cpm">
          <div class="cpm-h"><span class="cpm-l">${d.l}</span><span class="cpm-v" style="color:${sc(s[d.k]||0)}">${s[d.k]??'—'}${s[d.k]===best[d.k]?'<span class="wb">best</span>':''}</span></div>
          <div class="cpm-bg"><div class="cpm-fill" style="width:${s[d.k]||0}%;background:${d.c}"></div></div>
        </div>`).join('')}
        <hr class="csep">
        <div class="ckv"><span class="ckv-l">⭐ Stars</span><span class="ckv-v" style="color:${(r.stars||0)===best.stars?'var(--accent)':'var(--text)'}">${fmt(r.stars)}${(r.stars||0)===best.stars?'<span class="wb">best</span>':''}</span></div>
        <div class="ckv"><span class="ckv-l">📝 Commits/30T</span><span class="ckv-v">${k.commits30??'—'}</span></div>
        <div class="ckv"><span class="ckv-l">✅ Issue-Close-Rate</span><span class="ckv-v">${k.closeRate!=null?(k.closeRate*100).toFixed(0)+'%':'—'}</span></div>
        <div class="ckv"><span class="ckv-l">⏱ Issue-Schließzeit</span><span class="ckv-v">${k.avgClose!=null?k.avgClose.toFixed(0)+' T':'—'}</span></div>
        <div class="ckv"><span class="ckv-l">🚀 Release-Abstand</span><span class="ckv-v">${k.relFreq!=null?k.relFreq.toFixed(0)+' T':'—'}</span></div>
        <div class="ckv"><span class="ckv-l">🍴 Fork-Ratio</span><span class="ckv-v">${k.forkRatio!=null?(k.forkRatio*100).toFixed(1)+'%':'—'}</span></div>
        <div class="ckv"><span class="ckv-l">📄 Dokumentation</span><span class="ckv-v">${k.doku!=null?k.doku+' Pkt.':'—'}</span></div>
        <div class="ckv"><span class="ckv-l">👥 Contributors</span><span class="ckv-v">${k.contributors??'—'}</span></div>
      </div>`;
    grid.appendChild(card);
  });
  const body=document.getElementById('modalBody');body.innerHTML='';body.appendChild(grid);
}

loadData();
</script>
</body>
</html>
